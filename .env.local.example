# Local env vars for build-time tooling. Copy to .env.local and fill in.
# .env.local is gitignored.

# Unsplash — sign up at https://unsplash.com/oauth/applications
# Demo tier: 50 requests/hour, 5000/month. Free.
# Used by scripts/mcp-image-server.mjs (search_unsplash tool).
UNSPLASH_ACCESS_KEY=

# Pexels — sign up at https://www.pexels.com/api/
# Free, generous rate limit (200/hr, 20k/month).
# Used by both scripts/fetch-images.ts and scripts/mcp-image-server.mjs.
PEXELS_API_KEY=

# Google Places API — enable Places API at https://console.cloud.google.com/
# Free tier: ~$200/mo credit. Text Search is $0.032/call, Place Details is
# $0.017/call. First-pass enrichment of one contractor uses 2 calls (~$0.05).
# Used by scripts/mcp-contractor-server.mjs (lookup_google_places +
# fetch_google_reviews tools).
GOOGLE_PLACES_API_KEY=
